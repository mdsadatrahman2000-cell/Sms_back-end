generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// CORE TABLES
// ============================================================

model Tenant {
  id                     String   @id @default(uuid()) @db.Uuid
  name                   String
  slug                   String   @unique
  subdomain              String?  @unique
  domain                 String?
  logoUrl                String?  @map("logo_url")
  timezone               String   @default("UTC")
  currency               String   @default("USD")
  language               String   @default("en")
  plan                   String   @default("free")
  stripeCustomerId       String?  @map("stripe_customer_id")
  stripeSubscriptionId   String?  @map("stripe_subscription_id")
  settings               Json     @default("{}")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  users                  User[]
  roles                  Role[]
  classes                Class[]
  subjects               Subject[]
  academicYears          AcademicYear[]
  students               Student[]
  guardians              Guardian[]
  studentAttendances     StudentAttendance[]
  exams                  Exam[]
  marks                  Mark[]
  feeStructures          FeeStructure[]
  invoices               Invoice[]
  payments               Payment[]
  courses                Course[]
  assignments            Assignment[]
  assignmentSubmissions  AssignmentSubmission[]
  messages               Message[]
  notices                Notice[]
  auditLogs              AuditLog[]
  userRoles              UserRole[]
  classSubjects          ClassSubject[]
  documents              Document[]
  books                  Book[]
  bookIssues             BookIssue[]
  transportRoutes        TransportRoute[]
  studentTransport       StudentTransport[]
  hostels                Hostel[]
  hostelRooms            HostelRoom[]
  hostelAllocations      HostelAllocation[]
  inventoryItems         InventoryItem[]
  stockMovements         StockMovement[]
  timetableSlots         TimetableSlot[]

  @@map("tenants")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  email           String
  passwordHash    String?   @map("password_hash")
  refreshTokenHash String?  @map("refresh_token_hash")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  phone           String?
  avatarUrl       String?   @map("avatar_url")
  emailVerified   Boolean   @default(false) @map("email_verified")
  phoneVerified   Boolean   @default(false) @map("phone_verified")
  lastLoginAt     DateTime? @map("last_login_at")
  status          String    @default("active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  student         Student?
  guardian        Guardian?
  markedAttendances StudentAttendance[] @relation("marked_by")
  enteredMarks    Mark[]    @relation("entered_by")
  gradedSubmissions AssignmentSubmission[] @relation("graded_by")
  sentMessages    Message[]
  receivedMessages MessageRecipient[]
  createdNotices  Notice[]
  auditLogs       AuditLog[]
  teachingClasses Class[]   @relation("classTeacher")
  classSubjects   ClassSubject[]
  teachingCourses Course[]
  teachingAssignments Assignment[]
  uploadedDocuments Document[]
  timetableSlots  TimetableSlot[]

  @@unique([tenantId, email])
  @@index([tenantId, email])
  @@index([tenantId, status])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  module      String
  action      String

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId, userId])
  @@map("user_roles")
}

// ============================================================
// ACADEMIC TABLES
// ============================================================

model AcademicYear {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  startDate DateTime @db.Date @map("start_date")
  endDate   DateTime @db.Date @map("end_date")
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classes      Class[]
  feeStructures FeeStructure[]

  @@unique([tenantId, name])
  @@map("academic_years")
}

model Class {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String
  gradeLevel      Int?     @map("grade_level")
  section         String?
  maxCapacity     Int      @default(40) @map("max_capacity")
  classTeacherId  String?  @map("class_teacher_id") @db.Uuid
  academicYearId  String   @map("academic_year_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear   @relation(fields: [academicYearId], references: [id])
  classTeacher    User?          @relation("classTeacher", fields: [classTeacherId], references: [id])
  classSubjects   ClassSubject[]
  students        Student[]
  studentAttendances StudentAttendance[]
  exams           Exam[]
  feeStructures   FeeStructure[]
  courses         Course[]
  assignments     Assignment[]
  timetableSlots  TimetableSlot[]

  @@unique([tenantId, name, section, academicYearId])
  @@index([tenantId])
  @@map("classes")
}

model Subject {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String
  code         String?
  description  String?
  isElective   Boolean  @default(false) @map("is_elective")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classSubjects ClassSubject[]
  exams         Exam[]
  courses       Course[]
  assignments   Assignment[]
  timetableSlots TimetableSlot[]

  @@unique([tenantId, code])
  @@map("subjects")
}

model ClassSubject {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  classId     String   @map("class_id") @db.Uuid
  subjectId   String   @map("subject_id") @db.Uuid
  teacherId   String   @map("teacher_id") @db.Uuid
  scheduleDay Int?     @map("schedule_day")
  scheduleTime DateTime? @map("schedule_time")
  room        String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher User    @relation(fields: [teacherId], references: [id])

  @@unique([tenantId, classId, subjectId])
  @@map("class_subjects")
}

// ============================================================
// STUDENT TABLES
// ============================================================

model Student {
  id                     String    @id @default(uuid()) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  userId                 String    @unique @map("user_id") @db.Uuid
  admissionNumber        String    @map("admission_number")
  rollNumber             String?   @map("roll_number")
  classId                String?   @map("class_id") @db.Uuid
  section                String?
  house                  String?
  club                   String?
  bloodGroup             String?   @map("blood_group")
  medicalConditions      String?   @map("medical_conditions")
  emergencyContactName   String?   @map("emergency_contact_name")
  emergencyContactPhone  String?   @map("emergency_contact_phone")
  nationality            String?
  visaStatus             String?   @map("visa_status")
  previousSchool         String?   @map("previous_school")
  admissionDate          DateTime? @default(now()) @map("admission_date") @db.Date
  status                 String    @default("active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  class           Class?             @relation(fields: [classId], references: [id])
  studentGuardians StudentGuardian[]
  attendances     StudentAttendance[]
  marks           Mark[]
  assignmentSubmissions AssignmentSubmission[]
  invoices        Invoice[]
  bookIssues      BookIssue[]
  transport       StudentTransport?
  hostelAllocation HostelAllocation?

  @@unique([tenantId, admissionNumber])
  @@index([tenantId, classId])
  @@index([tenantId, status])
  @@map("students")
}

model Guardian {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  relationship String
  occupation   String?
  workPhone    String?  @map("work_phone")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentGuardians StudentGuardian[]
  invoices         Invoice[]

  @@map("guardians")
}

model StudentGuardian {
  studentId  String @map("student_id") @db.Uuid
  guardianId String @map("guardian_id") @db.Uuid

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
  @@map("student_guardians")
}

// ============================================================
// ATTENDANCE TABLES
// ============================================================

model StudentAttendance {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  studentId  String    @map("student_id") @db.Uuid
  classId    String    @map("class_id") @db.Uuid
  date       DateTime  @db.Date
  status     String
  checkInTime DateTime? @map("check_in_time")
  checkOutTime DateTime? @map("check_out_time")
  method     String    @default("manual")
  notes      String?
  markedBy   String?   @map("marked_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  marker  User?   @relation("marked_by", fields: [markedBy], references: [id])

  @@unique([tenantId, studentId, date])
  @@index([tenantId, date])
  @@index([tenantId, studentId])
  @@map("student_attendance")
}

// ============================================================
// EXAMINATION TABLES
// ============================================================

model Exam {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  type          String
  classId       String   @map("class_id") @db.Uuid
  subjectId     String   @map("subject_id") @db.Uuid
  startDate     DateTime @db.Date @map("start_date")
  endDate       DateTime @db.Date @map("end_date")
  totalMarks    Int      @map("total_marks")
  passingMarks  Int      @map("passing_marks")
  weightage     Decimal? @db.Decimal(5, 2)
  status        String   @default("draft")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class    Class    @relation(fields: [classId], references: [id])
  subject  Subject  @relation(fields: [subjectId], references: [id])
  marks    Mark[]

  @@index([tenantId, classId])
  @@map("exams")
}

model Mark {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  examId        String    @map("exam_id") @db.Uuid
  studentId     String    @map("student_id") @db.Uuid
  marksObtained Decimal?  @db.Decimal(5, 2) @map("marks_obtained")
  grade         String?
  remarks       String?
  enteredBy     String?   @map("entered_by") @db.Uuid
  enteredAt     DateTime? @map("entered_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enterer User?   @relation("entered_by", fields: [enteredBy], references: [id])

  @@unique([tenantId, examId, studentId])
  @@index([tenantId, examId])
  @@index([tenantId, studentId])
  @@map("marks")
}

// ============================================================
// FINANCE TABLES
// ============================================================

model FeeStructure {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String
  classId         String   @map("class_id") @db.Uuid
  academicYearId  String   @map("academic_year_id") @db.Uuid
  totalAmount     Decimal  @db.Decimal(12, 2) @map("total_amount")
  installments    Int      @default(1)
  dueDate         DateTime? @db.Date @map("due_date")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class           Class               @relation(fields: [classId], references: [id])
  academicYear    AcademicYear        @relation(fields: [academicYearId], references: [id])
  items           FeeStructureItem[]
  invoices        Invoice[]

  @@map("fee_structures")
}

model FeeStructureItem {
  id             String   @id @default(uuid()) @db.Uuid
  feeStructureId String   @map("fee_structure_id") @db.Uuid
  name           String
  amount         Decimal  @db.Decimal(12, 2)
  isMandatory    Boolean  @default(true) @map("is_mandatory")
  createdAt      DateTime @default(now()) @map("created_at")

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@map("fee_structure_items")
}

model Invoice {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  invoiceNumber   String   @map("invoice_number")
  studentId       String   @map("student_id") @db.Uuid
  parentId        String   @map("parent_id") @db.Uuid
  feeStructureId  String   @map("fee_structure_id") @db.Uuid
  totalAmount     Decimal  @db.Decimal(12, 2) @map("total_amount")
  paidAmount      Decimal  @default(0) @db.Decimal(12, 2) @map("paid_amount")
  dueDate         DateTime @db.Date @map("due_date")
  status          String   @default("unpaid")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id])
  parent      Guardian    @relation(fields: [parentId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  payments    Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, studentId])
  @@index([tenantId, status])
  @@map("invoices")
}

model Payment {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  paymentNumber   String    @map("payment_number")
  invoiceId       String    @map("invoice_id") @db.Uuid
  amount          Decimal   @db.Decimal(12, 2)
  method          String
  gateway         String?
  transactionRef  String?   @map("transaction_ref")
  idempotencyKey  String?   @unique @map("idempotency_key")
  status          String    @default("pending")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, paymentNumber])
  @@index([tenantId, invoiceId])
  @@map("payments")
}

// ============================================================
// LMS TABLES
// ============================================================

model Course {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  title       String
  description String?
  subjectId   String?       @map("subject_id") @db.Uuid
  teacherId   String        @map("teacher_id") @db.Uuid
  classId     String?       @map("class_id") @db.Uuid
  thumbnailUrl String?      @map("thumbnail_url")
  status      String        @default("draft")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subject  Subject?       @relation(fields: [subjectId], references: [id])
  teacher  User           @relation(fields: [teacherId], references: [id])
  class    Class?         @relation(fields: [classId], references: [id])
  modules  CourseModule[]

  @@map("courses")
}

model CourseModule {
  id          String   @id @default(uuid()) @db.Uuid
  courseId     String   @map("course_id") @db.Uuid
  title       String
  description String?
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("course_modules")
}

model Lesson {
  id          String   @id @default(uuid()) @db.Uuid
  moduleId    String   @map("module_id") @db.Uuid
  title       String
  contentType String   @map("content_type")
  contentUrl  String?  @map("content_url")
  contentText String?  @map("content_text")
  durationMinutes Int? @map("duration_minutes")
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")

  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

// ============================================================
// ASSIGNMENT TABLES
// ============================================================

model Assignment {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  title                String
  description          String?
  classId              String   @map("class_id") @db.Uuid
  subjectId            String   @map("subject_id") @db.Uuid
  teacherId            String   @map("teacher_id") @db.Uuid
  totalMarks           Int?     @map("total_marks")
  dueDate              DateTime @map("due_date")
  allowLateSubmission  Boolean  @default(false) @map("allow_late_submission")
  latePenaltyPercent   Decimal? @db.Decimal(5, 2) @map("late_penalty_percent")
  status               String   @default("draft")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class       Class                 @relation(fields: [classId], references: [id])
  subject     Subject               @relation(fields: [subjectId], references: [id])
  teacher     User                  @relation(fields: [teacherId], references: [id])
  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  assignmentId String    @map("assignment_id") @db.Uuid
  studentId    String    @map("student_id") @db.Uuid
  submissionUrl String?  @map("submission_url")
  submissionText String? @map("submission_text")
  submittedAt  DateTime? @default(now()) @map("submitted_at")
  marksObtained Decimal? @db.Decimal(5, 2) @map("marks_obtained")
  grade        String?
  feedback     String?
  gradedBy     String?   @map("graded_by") @db.Uuid
  gradedAt     DateTime? @map("graded_at")
  status       String    @default("submitted")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id])
  grader     User?      @relation("graded_by", fields: [gradedBy], references: [id])

  @@unique([tenantId, assignmentId, studentId])
  @@map("assignment_submissions")
}

// ============================================================
// COMMUNICATION TABLES
// ============================================================

model Message {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  senderId    String              @map("sender_id") @db.Uuid
  subject     String?
  content     String
  type        String              @default("direct")
  createdAt   DateTime            @default(now()) @map("created_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender     User              @relation(fields: [senderId], references: [id])
  recipients MessageRecipient[]

  @@map("messages")
}

model MessageRecipient {
  messageId String    @map("message_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  readAt    DateTime? @map("read_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@id([messageId, userId])
  @@map("message_recipients")
}

model Notice {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  title          String
  content        String
  targetAudience String[] @map("target_audience")
  priority       String   @default("normal")
  publishedAt    DateTime? @map("published_at")
  expiresAt      DateTime? @map("expires_at")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User?   @relation(fields: [createdBy], references: [id])

  @@index([tenantId, createdAt])
  @@map("notices")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@map("audit_logs")
}

// ============================================================
// FILE UPLOAD TABLES
// ============================================================

model Document {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  uploaderId   String   @map("uploader_id") @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id") @db.Uuid
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  fileSize     Int      @map("file_size")
  storageKey   String   @map("storage_key")
  category     String   @default("general")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploaderId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@map("documents")
}

// ============================================================
// LIBRARY TABLES
// ============================================================

model Book {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  title         String
  author        String
  isbn          String?
  publisher     String?
  category      String?
  shelfLocation String?  @map("shelf_location")
  quantity      Int      @default(1)
  available     Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issues BookIssue[]

  @@index([tenantId])
  @@map("books")
}

model BookIssue {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  bookId      String    @map("book_id") @db.Uuid
  studentId   String    @map("student_id") @db.Uuid
  issueDate   DateTime  @default(now()) @map("issue_date") @db.Date
  dueDate     DateTime  @map("due_date") @db.Date
  returnDate  DateTime? @map("return_date") @db.Date
  status      String    @default("issued")
  fineAmount  Decimal?  @db.Decimal(10, 2) @map("fine_amount")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id])

  @@index([tenantId, bookId])
  @@index([tenantId, studentId])
  @@map("book_issues")
}

// ============================================================
// TRANSPORT TABLES
// ============================================================

model TransportRoute {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  vehicleNumber String?  @map("vehicle_number")
  driverName    String?  @map("driver_name")
  driverPhone   String?  @map("driver_phone")
  monthlyFee    Decimal? @db.Decimal(10, 2) @map("monthly_fee")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stops    TransportStop[]
  students StudentTransport[]

  @@index([tenantId])
  @@map("transport_routes")
}

model TransportStop {
  id        String   @id @default(uuid()) @db.Uuid
  routeId   String   @map("route_id") @db.Uuid
  name      String
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  sortOrder Int      @default(0) @map("sort_order")

  route TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@map("transport_stops")
}

model StudentTransport {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  studentId String  @unique @map("student_id") @db.Uuid
  routeId   String  @map("route_id") @db.Uuid
  stopName  String? @map("stop_name")

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student          @relation(fields: [studentId], references: [id])
  route   TransportRoute   @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@map("student_transport")
}

// ============================================================
// HOSTEL TABLES
// ============================================================

model Hostel {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  address     String?
  capacity    Int      @default(0)
  wardenName  String?  @map("warden_name")
  wardenPhone String?  @map("warden_phone")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms  HostelRoom[]

  @@index([tenantId])
  @@map("hostels")
}

model HostelRoom {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  hostelId   String   @map("hostel_id") @db.Uuid
  roomNumber String   @map("room_number")
  type       String   @default("double")
  capacity   Int      @default(2)
  monthlyFee Decimal? @db.Decimal(10, 2) @map("monthly_fee")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostel      Hostel             @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  allocations HostelAllocation[]

  @@unique([tenantId, hostelId, roomNumber])
  @@map("hostel_rooms")
}

model HostelAllocation {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  roomId    String    @map("room_id") @db.Uuid
  studentId String    @unique @map("student_id") @db.Uuid
  startDate DateTime  @default(now()) @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  status    String    @default("active")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room    HostelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id])

  @@map("hostel_allocations")
}

// ============================================================
// INVENTORY TABLES
// ============================================================

model InventoryItem {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  category    String
  quantity    Int      @default(0)
  unitPrice   Decimal? @db.Decimal(12, 2) @map("unit_price")
  supplier    String?
  location    String?
  minStock    Int      @default(0) @map("min_stock")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movements StockMovement[]

  @@index([tenantId, category])
  @@map("inventory_items")
}

model StockMovement {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  itemId    String   @map("item_id") @db.Uuid
  type      String
  quantity  Int
  reason    String?
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([tenantId, itemId])
  @@map("stock_movements")
}

// ============================================================
// TIMETABLE TABLES
// ============================================================

model TimetableSlot {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  subjectId String   @map("subject_id") @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  room      String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher User    @relation(fields: [teacherId], references: [id])

  @@unique([tenantId, classId, dayOfWeek, startTime])
  @@map("timetable_slots")
}
